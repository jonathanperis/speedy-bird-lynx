---
const gaId = import.meta.env.PUBLIC_GA_ID;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const faviconHref = `${basePath}/favicon.ico`;

const jsonLd = `{
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": "Speedy Bird",
  "description": "A pixel art Speedy Bird clone built with Lynx cross-platform framework. Play in your browser or on mobile.",
  "url": "https://jonathanperis.github.io/speedy-bird-lynx/",
  "genre": ["Arcade", "Pixel Art", "Side-Scroller"],
  "gamePlatform": ["Web Browser", "iOS", "Android"],
  "applicationCategory": "Game",
  "operatingSystem": ["iOS", "Android", "Web"],
  "author": {
    "@type": "Person",
    "name": "Jonathan Peris",
    "url": "https://github.com/jonathanperis"
  },
  "isAccessibleForFree": true,
  "license": "https://github.com/jonathanperis/speedy-bird-lynx/blob/master/LICENSE",
  "codeRepository": "https://github.com/jonathanperis/speedy-bird-lynx"
}`;
---

<!doctype html>
<html lang="en">
<head>
  {gaId && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Speedy Bird - Pixel Art Side-Scroller</title>
  <meta name="description" content="A pixel art Speedy Bird clone built with Lynx cross-platform framework. Play in your browser or on mobile via Lynx native.">
  <meta name="keywords" content="Speedy Bird, pixel art, Lynx, ReactLynx, cross-platform, mobile game, side-scroller, open source">
  <link rel="icon" href={faviconHref} sizes="any">
  <link rel="canonical" href="https://jonathanperis.github.io/speedy-bird-lynx/">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Speedy Bird - Pixel Art Side-Scroller">
  <meta property="og:description" content="A pixel art Speedy Bird clone built with Lynx cross-platform framework. Play in your browser.">
  <meta property="og:url" content="https://jonathanperis.github.io/speedy-bird-lynx/">
  <meta property="og:site_name" content="Speedy Bird">
  <meta property="og:locale" content="en_US">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Speedy Bird - Pixel Art Side-Scroller">
  <meta name="twitter:description" content="A pixel art Speedy Bird clone built with Lynx. Play in your browser.">
  <meta name="twitter:creator" content="@jperis_silva">

  <!-- Theme -->
  <meta name="theme-color" content="#04111e">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800;900&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">

  <script type="application/ld+json" set:html={jsonLd}></script>

  <style is:global>
    :root {
      --sky-deep: #04111e;
      --sky-mid: #0a2a4a;
      --sky-dawn: #0d4a7a;
      --dawn-orange: #ff6b35;
      --golden: #ffd166;
      --pipe: #2d6a4f;
      --pipe-light: #4a9e6f;
      --text: #e8f8ff;
      --text-dim: #6ba8c8;
      --card-bg: rgba(10, 30, 60, 0.8);
      --card-border: rgba(30, 80, 140, 0.6);
      --gold: #ffd166;
      --gold-dim: #c9a000;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; overflow-x: hidden; }

    /* Custom scrollbar */
    html { scrollbar-color: var(--golden) var(--sky-deep); scrollbar-width: thin; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--sky-deep); border-left: 1px solid rgba(30, 80, 140, 0.3); }
    ::-webkit-scrollbar-thumb { background: var(--golden); border-radius: 3px; transition: background 0.2s; }
    ::-webkit-scrollbar-thumb:hover { background: #ffe08a; }
    ::-webkit-scrollbar-corner { background: var(--sky-deep); }

    body {
      background: linear-gradient(to bottom, var(--sky-deep), var(--sky-mid), var(--sky-dawn), #1a6fa8);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 400;
      min-height: 100vh;
      overflow-x: hidden;
      line-height: 1.6;
    }

    h1, h2, h3, h4, h5, h6 { font-family: 'Nunito', sans-serif; }

    /* Pill Navigation */
    .pill-nav {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%) translateY(-150%);
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 999px;
      padding: 0.5rem 1.5rem;
      display: flex;
      gap: 2rem;
      z-index: 100;
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .pill-nav.visible { transform: translateX(-50%) translateY(0); }
    .pill-nav a {
      color: var(--text);
      text-decoration: none;
      font-weight: 700;
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: color 0.2s;
    }
    .pill-nav a:hover { color: var(--gold); }

    /* Hero Section */
    .hero {
      position: relative;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      text-align: center;
    }
    
    /* CSS Clouds */
    .clouds-container {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      z-index: 0;
      pointer-events: none;
    }
    .cloud {
      position: absolute;
      background: #fff;
      border-radius: 50px;
      opacity: 0.15;
      animation: drift linear infinite;
    }
    .cloud::before, .cloud::after {
      content: '';
      position: absolute;
      background: #fff;
      border-radius: 50%;
    }
    .cloud-1 {
      width: 120px; height: 40px; top: 15%; left: 100%;
      animation-duration: 45s; animation-delay: -10s;
    }
    .cloud-1::before { width: 50px; height: 50px; top: -25px; left: 20px; }
    .cloud-1::after { width: 70px; height: 70px; top: -35px; left: 50px; }
    
    .cloud-2 {
      width: 180px; height: 50px; top: 40%; left: 100%;
      animation-duration: 60s; animation-delay: -30s; opacity: 0.1; transform: scale(1.5);
    }
    .cloud-2::before { width: 70px; height: 70px; top: -30px; left: 30px; }
    .cloud-2::after { width: 90px; height: 90px; top: -45px; left: 70px; }

    .cloud-3 {
      width: 100px; height: 30px; top: 65%; left: 100%;
      animation-duration: 35s; animation-delay: -5s; opacity: 0.2; transform: scale(0.8);
    }
    .cloud-3::before { width: 40px; height: 40px; top: -20px; left: 15px; }
    .cloud-3::after { width: 50px; height: 50px; top: -25px; left: 40px; }

    @keyframes drift {
      from { transform: translateX(10vw); }
      to { transform: translateX(-110vw); }
    }

    /* CSS Bird */
    .bird-wrapper {
      position: absolute;
      top: 25%;
      left: -100px;
      z-index: 1;
      animation: fly 20s linear infinite;
      animation-delay: 2s;
    }
    .bird {
      position: relative;
      width: 40px; height: 30px;
    }
    .bird-body {
      position: absolute;
      width: 32px; height: 24px;
      background: var(--gold);
      border-radius: 50%;
      top: 3px; left: 4px;
      border: 2px solid #000;
    }
    .bird-eye {
      position: absolute;
      width: 6px; height: 6px;
      background: #fff;
      border-radius: 50%;
      top: 6px; right: 8px;
      border: 1px solid #000;
    }
    .bird-eye::after {
      content: '';
      position: absolute;
      width: 2px; height: 2px;
      background: #000;
      border-radius: 50%;
      top: 2px; right: 1px;
    }
    .bird-beak {
      position: absolute;
      width: 12px; height: 8px;
      background: var(--dawn-orange);
      border-radius: 0 8px 8px 0;
      top: 12px; right: -2px;
      border: 1px solid #000;
    }
    .bird-wing {
      position: absolute;
      width: 18px; height: 10px;
      background: #fff;
      border-radius: 10px 10px 0 0;
      border: 1px solid #000;
      left: 6px; top: 10px;
      transform-origin: center top;
      animation: flap 0.3s infinite alternate ease-in-out;
    }
    .bird-wing-bot {
      background: #e0e0e0;
      animation-delay: -0.15s;
    }

    @keyframes fly {
      0% { transform: translateX(0) translateY(0) rotate(5deg); }
      25% { transform: translateX(30vw) translateY(-30px) rotate(-5deg); }
      50% { transform: translateX(60vw) translateY(20px) rotate(5deg); }
      75% { transform: translateX(90vw) translateY(-10px) rotate(-5deg); }
      100% { transform: translateX(120vw) translateY(0) rotate(5deg); }
    }
    @keyframes flap {
      0% { transform: rotateX(0deg) rotateZ(-20deg); }
      100% { transform: rotateX(60deg) rotateZ(30deg); }
    }

    .hero-content {
      position: relative;
      z-index: 10;
    }
    .hero-title {
      font-size: clamp(3.5rem, 10vw, 8rem);
      font-weight: 900;
      line-height: 1;
      margin-bottom: 1rem;
      background: linear-gradient(to bottom, #fff, #bce4ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      filter: drop-shadow(0 10px 20px rgba(0,0,0,0.5));
      letter-spacing: -2px;
    }
    .hero-tagline {
      font-size: clamp(1.2rem, 3vw, 1.8rem);
      color: var(--golden);
      font-weight: 500;
      margin-bottom: 2.5rem;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }
    .speed-badge {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      background: rgba(0,0,0,0.3);
      padding: 1rem 2rem;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.1);
      margin-bottom: 3rem;
      backdrop-filter: blur(5px);
    }
    .speed-num {
      font-family: 'Nunito', sans-serif;
      font-size: 3rem;
      font-weight: 800;
      color: var(--dawn-orange);
      line-height: 1;
    }
    .speed-label {
      font-size: 0.75rem;
      letter-spacing: 3px;
      opacity: 0.8;
      margin-top: 0.5rem;
      font-weight: 700;
    }
    .cta-btn {
      display: inline-block;
      background: var(--golden);
      color: #000;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 1.2rem;
      text-decoration: none;
      padding: 1.2rem 3rem;
      border-radius: 999px;
      text-transform: uppercase;
      letter-spacing: 2px;
      box-shadow: 0 10px 30px rgba(255, 209, 102, 0.3);
      transition: all 0.3s ease;
      animation: pulse 2s infinite;
    }
    .cta-btn:hover {
      transform: translateY(-5px) scale(1.05);
      box-shadow: 0 15px 40px rgba(255, 209, 102, 0.5);
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(255, 209, 102, 0.4); }
      70% { box-shadow: 0 0 0 20px rgba(255, 209, 102, 0); }
      100% { box-shadow: 0 0 0 0 rgba(255, 209, 102, 0); }
    }

    /* Pipe Divider */
    .pipe-divider {
      position: relative;
      height: 120px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
      margin: 4rem 0;
      animation: sway 6s ease-in-out infinite alternate;
    }
    .pipe {
      width: 100px;
      background: linear-gradient(90deg, #1e4d34 0%, var(--pipe) 20%, var(--pipe-light) 50%, var(--pipe) 80%, #1e4d34 100%);
      border: 3px solid #000;
    }
    .pipe-top {
      height: 40px;
      border-radius: 0 0 4px 4px;
      border-top: none;
      position: relative;
    }
    .pipe-top::after {
      content: '';
      position: absolute;
      bottom: -6px; left: -10px; right: -10px;
      height: 24px;
      background: linear-gradient(90deg, #1e4d34 0%, var(--pipe) 20%, var(--pipe-light) 50%, var(--pipe) 80%, #1e4d34 100%);
      border: 3px solid #000;
      border-radius: 4px;
    }
    .pipe-bot {
      height: 40px;
      border-radius: 4px 4px 0 0;
      border-bottom: none;
      position: relative;
    }
    .pipe-bot::before {
      content: '';
      position: absolute;
      top: -6px; left: -10px; right: -10px;
      height: 24px;
      background: linear-gradient(90deg, #1e4d34 0%, var(--pipe) 20%, var(--pipe-light) 50%, var(--pipe) 80%, #1e4d34 100%);
      border: 3px solid #000;
      border-radius: 4px;
    }
    .pipe-gap { height: 40px; }
    
    @keyframes sway {
      0% { transform: translateX(-10px); }
      100% { transform: translateX(10px); }
    }

    /* Game Section */
    .play-section {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 4rem 1rem;
      perspective: 1000px;
    }
    .phone-device {
      position: relative;
      width: 100%;
      max-width: 420px;
      background: #111;
      border-radius: 40px;
      padding: 10px;
      box-shadow: 
        0 30px 60px rgba(0,0,0,0.6),
        inset 0 0 0 2px #333,
        inset 0 0 20px rgba(255,255,255,0.1);
      transform: rotateX(2deg);
      transition: transform 0.5s ease;
    }
    .phone-device:hover { transform: rotateX(0deg); }
    .phone-chrome {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 30px;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 10;
    }
    .phone-camera {
      width: 12px; height: 12px;
      background: #000;
      border-radius: 50%;
      border: 2px solid #222;
      box-shadow: inset 0 1px 3px rgba(255,255,255,0.2);
    }
    .phone-screen {
      position: relative;
      background: #000;
      border-radius: 32px;
      overflow: hidden;
      aspect-ratio: 400 / 600;
      display: flex;
      flex-direction: column;
    }
    #canvas {
      display: block;
      width: 100%;
      height: auto;
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      cursor: pointer;
      background: #00bbc4;
    }
    .phone-chin {
      position: absolute;
      bottom: 20px; left: 0; right: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      z-index: 10;
      pointer-events: none;
    }
    .btn-row { pointer-events: auto; }
    #play-btn {
      background: var(--golden);
      color: #000;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 1.2rem;
      border: none;
      padding: 0.8rem 2.5rem;
      border-radius: 999px;
      cursor: pointer;
      text-transform: uppercase;
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
      transition: transform 0.1s, background 0.2s;
    }
    #play-btn:hover { transform: scale(1.05); }
    #play-btn:active { transform: scale(0.95); }
    #play-btn:disabled { opacity: 0.5; cursor: default; transform: none; }
    
    .game-controls {
      color: rgba(255,255,255,0.8);
      font-size: 0.85rem;
      background: rgba(0,0,0,0.6);
      padding: 0.5rem 1rem;
      border-radius: 999px;
      backdrop-filter: blur(4px);
    }
    .game-controls kbd {
      background: #333;
      border: 1px solid #555;
      border-radius: 4px;
      padding: 0.1rem 0.4rem;
      font-family: monospace;
      font-size: 0.8rem;
    }
    .home-bar {
      width: 120px;
      height: 4px;
      background: rgba(255,255,255,0.5);
      border-radius: 4px;
      margin-top: 10px;
    }

    /* About Section */
    .about-section {
      max-width: 1000px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    .about-section h2 {
      font-size: 2.5rem;
      font-weight: 900;
      color: var(--golden);
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      letter-spacing: -1px;
    }
    .about-section p {
      font-size: 1.1rem;
      color: var(--text);
      margin-bottom: 1.5rem;
      opacity: 0.9;
    }
    .about-game, .about-project, .about-lynx { margin-bottom: 5rem; }
    
    /* Speed Meter */
    .speed-meter {
      margin: 3rem 0;
      background: rgba(0,0,0,0.4);
      height: 24px;
      border-radius: 12px;
      position: relative;
      border: 1px solid rgba(255,255,255,0.1);
      overflow: hidden;
    }
    .speed-fill {
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 0%;
      background: linear-gradient(90deg, #4ade80, var(--golden), var(--dawn-orange));
      border-radius: 12px;
      transition: width 1.5s ease-out;
    }
    .speed-meter.visible .speed-fill { width: 100%; }
    .speed-labels {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 1rem;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 0.85rem;
      color: #fff;
      text-shadow: 0 1px 3px rgba(0,0,0,0.8);
      z-index: 2;
    }

    /* Medals */
    .medals-row {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
      margin: 3rem 0;
    }
    .medal {
      width: 100px; height: 100px;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 1rem;
      text-align: center;
      color: #fff;
      text-shadow: 0 2px 4px rgba(0,0,0,0.5);
      border: 4px solid rgba(255,255,255,0.3);
      box-shadow: 0 10px 20px rgba(0,0,0,0.4), inset 0 0 20px rgba(255,255,255,0.5);
      transition: transform 0.3s;
    }
    .medal:hover { transform: translateY(-10px) scale(1.1); }
    .medal small { font-size: 0.75rem; opacity: 0.9; margin-top: 0.2rem; }
    
    .medal-bronze { background: linear-gradient(135deg, #cd7f32, #8b5a2b); border-color: #ffd700; }
    .medal-silver { background: linear-gradient(135deg, #e0e0e0, #9e9e9e); border-color: #fff; }
    .medal-gold { background: linear-gradient(135deg, #ffd700, #b8860b); border-color: #ffefd5; }
    .medal-platinum { background: linear-gradient(135deg, #e5e4e2, #b0e0e6, #87ceeb); border-color: #fff; color: #111; text-shadow: none; }

    /* Feature Grid (Platform Badges) */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .feature-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 16px;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 6px;
      background: var(--golden);
    }
    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.4);
    }
    .feature-card h3 {
      font-size: 1.25rem;
      color: #fff;
      margin-bottom: 0.75rem;
    }
    .feature-card p {
      font-size: 0.95rem;
      margin-bottom: 0;
      color: var(--text-dim);
    }

    /* Docs Section */
    .docs-section {
      max-width: 1000px;
      margin: 0 auto;
      padding: 4rem 1.5rem 8rem;
    }
    .docs-section h2 {
      font-size: 2.5rem;
      font-weight: 900;
      color: var(--golden);
      margin-bottom: 2rem;
      text-transform: uppercase;
      text-align: center;
    }
    .docs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .doc-card {
      background: rgba(0,0,0,0.3);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 1.5rem;
      text-decoration: none;
      color: var(--text);
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
      backdrop-filter: blur(5px);
    }
    .doc-card:hover {
      background: rgba(255, 209, 102, 0.1);
      border-color: var(--golden);
      transform: translateY(-5px);
    }
    .doc-card h3 {
      font-size: 1.1rem;
      color: var(--golden);
      margin-bottom: 0.5rem;
    }
    .doc-card p {
      font-size: 0.9rem;
      color: var(--text-dim);
      margin: 0;
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 3rem 1.5rem;
      background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
      color: var(--text-dim);
      font-size: 0.9rem;
    }
    footer a {
      color: var(--golden);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }
    footer a:hover { color: #fff; }

    /* Utilities */
    .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    
    @media (max-width: 600px) {
      .hero-title { font-size: 3rem; }
      .phone-device { border-radius: 30px; }
      .about-section h2 { font-size: 2rem; }
      .pill-nav { width: 90%; justify-content: space-around; gap: 0; }
    }
  

        /* === Enhanced Design System === */
        :root {
            --enhanced-accent: #FFD166;
            --enhanced-accent-dim: rgba(255, 209, 102, 0.15);
            --enhanced-accent-glow: rgba(255, 209, 102, 0.08);
            --enhanced-bg-deep: #04111e;
            --enhanced-bg-surface: #0a2030;
            --enhanced-text-primary: #e8f8ff;
            --enhanced-text-secondary: #6ba8c8;
            --enhanced-text-muted: #4a7a9a;
            --enhanced-border-subtle: rgba(255, 209, 102, 0.08);
            --enhanced-border-medium: rgba(255, 209, 102, 0.15);
        }

        /* Ambient Background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse at 30% 20%, rgba(255, 209, 102, 0.08) 0%, transparent 50%),
                        radial-gradient(ellipse at 70% 80%, rgba(255, 209, 102, 0.15) 0%, transparent 50%);
            pointer-events: none;
            z-index: -2;
            animation: ambient-drift 20s ease-in-out infinite alternate;
        }
        @keyframes ambient-drift {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(-5%, 3%) scale(1.05); }
        }

        /* Floating Particles */
        .particles {
            position: fixed;
            inset: 0;
            z-index: -1;
            pointer-events: none;
        }
        .particle {
            position: absolute;
            width: 2px; height: 2px;
            background: #FFD166;
            border-radius: 50%;
            opacity: 0;
            animation: particle-float linear infinite;
        }
        .particle:nth-child(1) { left: 10%; animation-duration: 15s; animation-delay: 0s; }
        .particle:nth-child(2) { left: 25%; animation-duration: 18s; animation-delay: -3s; }
        .particle:nth-child(3) { left: 40%; animation-duration: 12s; animation-delay: -6s; }
        .particle:nth-child(4) { left: 55%; animation-duration: 20s; animation-delay: -9s; }
        .particle:nth-child(5) { left: 70%; animation-duration: 16s; animation-delay: -12s; }
        .particle:nth-child(6) { left: 85%; animation-duration: 14s; animation-delay: -4s; }
        @keyframes particle-float {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            10% { opacity: 0.6; }
            90% { opacity: 0.6; }
            100% { transform: translateY(-10vh) scale(1); opacity: 0; }
        }

        /* Enhanced Nav */
        nav {
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            position: sticky;
            top: 0;
            z-index: 100;
            transition: all 0.3s;
        }
        nav:hover {
            background: rgba(10, 8, 6, 0.95);
        }
        .logo {
            font-family: 'JetBrains Mono', monospace;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s;
        }
        .logo::before {
            content: '';
            display: inline-block;
            width: 8px; height: 8px;
            background: #FFD166;
            border-radius: 2px;
            box-shadow: 0 0 8px #FFD166;
        }
        .nav-links {
            display: flex;
            gap: 2rem;
        }
        .nav-links a {
            position: relative;
            font-weight: 500;
            font-size: 0.875rem;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px; left: 0;
            width: 0; height: 1px;
            background: #FFD166;
            transition: width 0.3s ease;
        }
        .nav-links a:hover::after {
            width: 100%;
        }

        /* Enhanced Hero */
        .hero {
            animation: fade-up 0.8s ease-out both;
        }
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hero h1 {
            font-family: 'Inter', sans-serif;
            letter-spacing: -0.04em;
            line-height: 1;
            background: linear-gradient(135deg, #e8f8ff 0%, #FFD166 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .tagline {
            font-family: 'Inter', sans-serif;
            line-height: 1.7;
        }

        /* Enhanced Badges */
        .badges {
            gap: 0.75rem;
        }
        .badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            font-weight: 500;
            border-radius: 8px;
            transition: all 0.2s;
            padding: 0.4rem 1rem;
        }
        .badge:hover {
            border-color: #FFD166;
            color: #FFD166;
            background: rgba(255, 209, 102, 0.15);
            transform: translateY(-2px);
        }

        /* Enhanced CTAs */
        .btn {
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
            border-radius: 12px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        .btn-primary {
            box-shadow: 0 4px 20px rgba(255, 209, 102, 0.15);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(255, 209, 102, 0.15);
        }
        .btn-outline {
            border: 1px solid rgba(255, 209, 102, 0.15);
        }
        .btn-outline:hover {
            border-color: #FFD166;
            background: rgba(255, 209, 102, 0.15);
            transform: translateY(-2px);
        }

        /* Enhanced Specs/Dashboard */
        .specs, .dashboard {
            background: #0a2030;
            border: 1px solid rgba(255, 209, 102, 0.08);
            border-radius: 20px;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            animation: fade-up 0.8s ease-out 0.2s both;
        }
        .specs::before, .dashboard::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, #FFD166, transparent);
        }
        .specs::after, .dashboard::after {
            content: '';
            position: absolute;
            top: -50%; right: -20%;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(255, 209, 102, 0.15) 0%, transparent 70%);
            pointer-events: none;
        }
        .grid-3, .stats-grid {
            position: relative;
            z-index: 1;
        }
        .spec-item, .stat-item {
            text-align: center;
            padding: 1.5rem;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            border: 1px solid rgba(255, 209, 102, 0.08);
            transition: all 0.3s;
        }
        .spec-item:hover, .stat-item:hover {
            border-color: rgba(255, 209, 102, 0.15);
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .spec-val, .stat-item h3 {
            font-family: 'JetBrains Mono', monospace;
            color: #FFD166;
            letter-spacing: -0.02em;
        }
        .spec-label, .stat-item p {
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 500;
        }
        .arch-list, .arch-info {
            position: relative;
            z-index: 1;
        }
        .arch-list div {
            padding: 0.5rem 1rem;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 8px;
            border: 1px solid rgba(255, 209, 102, 0.08);
            transition: all 0.2s;
        }
        .arch-list div:hover {
            border-color: rgba(255, 209, 102, 0.15);
            background: rgba(255, 209, 102, 0.15);
        }

        /* Enhanced Footer */
        footer {
            border-top: 1px solid rgba(255, 209, 102, 0.08);
        }
        footer a {
            transition: color 0.2s;
        }
        footer a:hover {
            color: #e8f8ff;
        }

        @media (max-width: 768px) {
            main { padding: 4rem 1.5rem 2rem; }
            .specs, .dashboard { padding: 2rem 1.5rem; }
            nav { padding: 1rem 1.5rem; }
            .nav-links { gap: 1rem; }
        }

    /* === Night Arcade Cabinet overhaul === */
    :root {
      --stroke-dark: #07131f;
      --panel-blue: #0a1e3c;
      --sky-surface: #0d1e3a;
      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --shadow-press: 0 4px 0 var(--stroke-dark);
    }

    body {
      background:
        radial-gradient(circle at 18% 14%, rgba(255, 209, 102, 0.10), transparent 28rem),
        radial-gradient(circle at 82% 62%, rgba(255, 107, 53, 0.08), transparent 30rem),
        linear-gradient(to bottom, var(--sky-deep), var(--sky-mid) 42%, var(--sky-dawn) 100%);
      padding-left: env(safe-area-inset-left);
      padding-right: env(safe-area-inset-right);
    }

    a:focus-visible,
    button:focus-visible,
    canvas:focus-visible {
      outline: 3px solid rgba(255, 209, 102, 0.85);
      outline-offset: 4px;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 28vh;
      background: linear-gradient(to top, rgba(4, 17, 30, 0.55), transparent);
      pointer-events: none;
      z-index: 1;
    }

    .hero-content {
      width: min(1100px, calc(100vw - 32px));
      display: grid;
      justify-items: center;
      gap: clamp(1rem, 2vw, 1.5rem);
      padding-top: 3rem;
    }

    .cabinet-kicker,
    .section-kicker,
    .panel-code,
    .doc-index {
      font-family: 'Nunito', system-ui, sans-serif;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--golden);
    }

    .cabinet-kicker {
      padding: 0.55rem 0.85rem;
      background: var(--stroke-dark);
      border: 2px solid var(--pipe-light);
      border-radius: 4px;
      box-shadow: var(--shadow-press);
    }

    .hero-title {
      background: none !important;
      -webkit-background-clip: initial !important;
      -webkit-text-fill-color: #e8f8ff !important;
      color: #e8f8ff;
      letter-spacing: -0.035em;
      text-shadow:
        4px 0 0 var(--stroke-dark),
        -4px 0 0 var(--stroke-dark),
        0 4px 0 var(--stroke-dark),
        0 -4px 0 var(--stroke-dark),
        8px 8px 0 rgba(255, 209, 102, 0.28);
      filter: none !important;
      margin-bottom: 0;
      text-wrap: balance;
    }

    .hero-tagline,
    .section-lede,
    .docs-lede {
      max-width: 62ch;
      color: var(--text);
      opacity: 0.96;
      text-wrap: pretty;
    }

    .hero-hud {
      display: grid;
      grid-template-columns: repeat(3, minmax(130px, 1fr));
      gap: 0.75rem;
      width: min(620px, 100%);
      margin: 0.5rem 0;
    }

    .hero-hud-card,
    .speed-badge {
      min-height: 86px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      background: var(--sky-surface) !important;
      border: 2px solid rgba(74, 158, 111, 0.88) !important;
      border-radius: 4px !important;
      padding: 0.75rem 1rem !important;
      margin: 0 !important;
      box-shadow: var(--shadow-press);
      backdrop-filter: none !important;
      color: var(--text);
    }

    .hero-hud-card strong,
    .speed-num,
    .speed-x {
      color: var(--dawn-orange);
      font-family: 'Nunito', system-ui, sans-serif;
      font-weight: 900;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }

    .hero-hud-card strong,
    .speed-num { font-size: clamp(1.8rem, 4vw, 3rem); }
    .speed-x { font-size: clamp(1.25rem, 3vw, 2rem); }
    .hero-hud-card span:not(.speed-num):not(.speed-x), .speed-label { color: var(--text-dim); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 900; }
    .speed-readout { display: flex; align-items: baseline; gap: 0.1rem; }

    .hero-actions,
    .docs-cta-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.8rem;
      align-items: center;
    }

    .cta-btn,
    #play-btn,
    .secondary-btn {
      border: 2px solid var(--stroke-dark);
      border-radius: 4px;
      box-shadow: var(--shadow-press);
      font-family: 'Nunito', system-ui, sans-serif;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: transform 140ms var(--ease-out-expo), box-shadow 140ms var(--ease-out-expo), background-color 180ms, color 180ms, border-color 180ms;
      animation: none !important;
    }

    .cta-btn,
    #play-btn {
      background: var(--golden);
      color: var(--stroke-dark);
    }

    .secondary-btn {
      display: inline-block;
      background: var(--stroke-dark);
      color: var(--text);
      text-decoration: none;
      padding: 1rem 1.3rem;
      font-size: 0.9rem;
      border-color: var(--pipe-light);
    }

    .cta-btn:hover,
    #play-btn:hover,
    .secondary-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 0 var(--stroke-dark);
    }

    .cta-btn:active,
    #play-btn:active,
    .secondary-btn:active {
      transform: translateY(3px);
      box-shadow: 0 1px 0 var(--stroke-dark);
    }

    .hero-control-note {
      color: var(--text-dim);
      font-size: 0.95rem;
      margin: 0;
    }

    .pill-nav {
      background: var(--stroke-dark) !important;
      border: 2px solid var(--pipe-light) !important;
      border-radius: 4px !important;
      box-shadow: var(--shadow-press);
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      gap: 0.25rem !important;
      padding: 0.35rem !important;
      transition: transform 280ms var(--ease-out-expo) !important;
    }

    .pill-nav a {
      border-radius: 3px;
      padding: 0.55rem 0.75rem;
      font-size: 0.78rem;
      letter-spacing: 0.1em;
    }

    .pill-nav a:hover { background: var(--golden); color: var(--stroke-dark) !important; }

    .pipe-divider { animation: none !important; margin: clamp(2rem, 5vw, 4rem) 0; }
    .pipe { border-color: var(--stroke-dark) !important; }

    .play-section {
      padding: clamp(3rem, 8vw, 6rem) 1rem;
      background: linear-gradient(180deg, transparent, rgba(4,17,30,0.18), transparent);
    }

    .phone-device {
      background: linear-gradient(180deg, #13233c, #07131f) !important;
      border: 3px solid var(--stroke-dark);
      border-radius: 28px !important;
      box-shadow: 0 24px 60px rgba(4, 17, 30, 0.55), 0 6px 0 var(--stroke-dark) !important;
      transform: none !important;
      transition: transform 220ms var(--ease-out-expo) !important;
    }

    .phone-device:hover { transform: translateY(-4px) !important; }
    .phone-camera, .phone-screen { background: var(--stroke-dark) !important; }
    .phone-screen { border-radius: 20px !important; border: 2px solid rgba(255, 209, 102, 0.25); }
    .game-controls { background: var(--stroke-dark) !important; border: 1px solid rgba(255, 209, 102, 0.32); border-radius: 4px !important; backdrop-filter: none !important; }
    .game-controls kbd { background: var(--sky-surface); border-color: var(--pipe-light); font-family: 'Space Grotesk', system-ui, sans-serif; }

    .about-section,
    .docs-section {
      max-width: 1120px;
      padding-block: clamp(3rem, 7vw, 6rem);
    }

    .about-game,
    .about-project,
    .about-lynx { margin-bottom: clamp(4rem, 9vw, 7rem); }

    .about-section h2,
    .docs-section h2 {
      color: var(--text);
      font-size: clamp(2.2rem, 6vw, 4.8rem);
      line-height: 0.95;
      letter-spacing: -0.045em;
      text-shadow: 3px 3px 0 var(--stroke-dark);
      text-wrap: balance;
    }

    .section-kicker { display: block; margin-bottom: 0.75rem; }
    .text-link { color: var(--golden); font-weight: 800; }

    .difficulty-track {
      position: relative;
      min-height: 240px;
      margin: 3rem 0 2rem;
      padding: 2rem 1rem 1rem;
      background: rgba(10, 30, 60, 0.5);
      border: 2px solid rgba(74, 158, 111, 0.75);
      border-radius: 4px;
      box-shadow: var(--shadow-press);
    }

    .track-line {
      position: absolute;
      left: 8%;
      right: 8%;
      top: 92px;
      height: 18px;
      background: var(--stroke-dark);
      border: 2px solid var(--stroke-dark);
      border-radius: 4px;
      overflow: hidden;
    }

    .speed-fill {
      inset: 0 auto 0 0;
      width: 100%;
      transform: scaleX(0);
      transform-origin: left center;
      background: linear-gradient(90deg, var(--pipe-light), var(--golden), var(--dawn-orange));
      border-radius: 0;
      transition: transform 900ms var(--ease-out-expo);
    }

    .speed-meter.visible .speed-fill,
    .difficulty-track.visible .speed-fill { transform: scaleX(1); }

    .track-marker {
      position: absolute;
      top: 38px;
      width: 120px;
      transform: translateX(-50%);
      text-align: center;
      display: grid;
      gap: 0.25rem;
    }

    .marker-start { left: 8%; }
    .marker-bronze { left: 24%; }
    .marker-silver { left: 40%; }
    .marker-gold { left: 64%; }
    .marker-platinum { left: 92%; }

    .marker-value {
      justify-self: center;
      display: grid;
      place-items: center;
      width: 64px;
      height: 64px;
      background: var(--golden);
      color: var(--stroke-dark);
      border: 2px solid var(--stroke-dark);
      border-radius: 4px;
      box-shadow: var(--shadow-press);
      font-family: 'Nunito', system-ui, sans-serif;
      font-weight: 900;
    }

    .track-marker strong { color: var(--text); font-family: 'Nunito', system-ui, sans-serif; text-transform: uppercase; }
    .track-marker small { color: var(--text-dim); font-weight: 700; }

    .medal-cabinet,
    .lynx-strip {
      background: var(--panel-blue);
      border: 2px solid rgba(255, 209, 102, 0.55);
      border-radius: 4px;
      box-shadow: var(--shadow-press);
      padding: clamp(1rem, 3vw, 1.5rem);
    }

    .cabinet-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      margin-bottom: 1rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-family: 'Nunito', system-ui, sans-serif;
      font-weight: 900;
    }

    .cabinet-header strong { color: var(--golden); }
    .medal-slots { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; }

    .medal {
      width: auto !important;
      height: 132px !important;
      border-radius: 4px !important;
      box-shadow: inset 0 0 0 3px rgba(255,255,255,0.12), var(--shadow-press) !important;
      transition: transform 180ms var(--ease-out-expo), box-shadow 180ms var(--ease-out-expo) !important;
    }

    .medal:hover { transform: translateY(-3px) !important; box-shadow: inset 0 0 0 3px rgba(255,255,255,0.12), 0 7px 0 var(--stroke-dark) !important; }
    .medal span { font-size: 1.1rem; text-transform: uppercase; }

    .manual-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-top: 2rem;
    }

    .manual-panel,
    .doc-card {
      background: var(--panel-blue) !important;
      border: 2px solid rgba(74, 158, 111, 0.75) !important;
      border-radius: 4px !important;
      padding: clamp(1rem, 2.4vw, 1.5rem) !important;
      box-shadow: var(--shadow-press);
      backdrop-filter: none !important;
      color: var(--text);
      transition: transform 180ms var(--ease-out-expo), border-color 180ms, background-color 180ms !important;
    }

    .manual-panel:hover,
    .doc-card:hover {
      transform: translateY(-3px) !important;
      border-color: var(--golden) !important;
      background: #0d2547 !important;
    }

    .panel-wide { grid-column: span 2; }
    .manual-panel h3,
    .doc-card h3 { color: var(--text) !important; margin: 0.5rem 0 0.65rem; }
    .manual-panel p,
    .doc-card p { color: var(--text-dim) !important; margin: 0; max-width: 65ch; }

    .lynx-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .lynx-strip span {
      color: var(--golden);
      border: 1px solid rgba(255, 209, 102, 0.35);
      border-radius: 4px;
      padding: 0.55rem 0.75rem;
      font-family: 'Nunito', system-ui, sans-serif;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.78rem;
    }

    .docs-section { text-align: center; }
    .docs-grid { text-align: left; }
    .docs-primary, .docs-secondary { font-size: 0.9rem !important; padding: 0.9rem 1.25rem !important; }
    .doc-index { color: var(--dawn-orange); }

    .feature-card::before { display: none; }
    .reveal { transition: opacity 520ms var(--ease-out-expo), transform 520ms var(--ease-out-expo) !important; }

    footer { background: linear-gradient(to top, rgba(4, 17, 30, 0.86), transparent) !important; border-top: 2px solid rgba(74, 158, 111, 0.45); }

    @media (max-width: 820px) {
      .hero { min-height: 100dvh; height: auto; padding: 5rem 0 3rem; }
      .hero-hud { grid-template-columns: 1fr; max-width: 300px; }
      .hero-title { font-size: clamp(3.2rem, 18vw, 5.5rem); }
      .pill-nav { width: calc(100% - 24px) !important; overflow-x: auto; justify-content: flex-start !important; }
      .pill-nav a { white-space: nowrap; }
      .difficulty-track { min-height: 560px; padding-top: 1rem; }
      .track-line { left: 40px; right: auto; top: 56px; bottom: 56px; width: 18px; height: auto; }
      .speed-fill { width: 100%; height: 100%; transform: scaleY(0); transform-origin: center top; background: linear-gradient(180deg, var(--pipe-light), var(--golden), var(--dawn-orange)); }
