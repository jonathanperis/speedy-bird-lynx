  <script is:inline>
    // Pill nav appear
    const heroEl = document.querySelector('.hero');
    const navEl = document.getElementById('pill-nav');
    if (window.IntersectionObserver) {
      new IntersectionObserver(([e]) => navEl.classList.toggle('visible', !e.isIntersecting)).observe(heroEl);
    }
    
    // Speed counter loop
    let spd = 1.0;
    const spdEl = document.getElementById('speedNum');
    if (spdEl) {
      setInterval(() => {
        spd += 0.01;
        if (spd > 1.73) spd = 1.0;
        spdEl.textContent = spd.toFixed(2);
      }, 50);
    }
    
    // Section reveals
    if (window.IntersectionObserver) {
      document.querySelectorAll('.reveal').forEach(el => {
        new IntersectionObserver(([e]) => { if (e.isIntersecting) el.classList.add('visible'); }, { threshold: 0.1 }).observe(el);
      });
      // Speed meter reveal separately for its animation
      const meter = document.getElementById('speedMeter');
      if (meter) {
        new IntersectionObserver(([e]) => { if (e.isIntersecting) meter.classList.add('visible'); }, { threshold: 0.5 }).observe(meter);
      }
    } else {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
    }
    
    // Init immediate reveals
    setTimeout(() => {
      document.querySelector('.hero-content').classList.add('visible');
    }, 100);
  </script>

  <!-- CRITICAL: Canvas game engine — VERBATIM (asset paths updated: ../assets/ → ./assets/) -->
  <script is:inline>
  /* ── Speedy Bird — Pure JS Canvas Implementation ─────────────── */
  (function() {
    'use strict';

    /* ── Constants (matching Lynx build exactly) ─────────────────── */
    var W = 400, H = 600;
    var BIRD_X = 80, BIRD_Y_START = 280, BIRD_W = 34, BIRD_H = 24, BIRD_R = 12;
    var FLAP = 7.25, GRAVITY = 0.28;
    var ROT_UP = -15, ROT_NEUTRAL = 0, ROT_DOWN = 70;
    var PIPE_W = 55, PIPE_H = 300, PIPE_GAP = 150, PIPE_DX = 2.7;
    var PIPE_MIN_Y = -200, PIPE_MAX_Y = -80, PIPE_SPAWN = 77;
    var BG_W = 276, BG_H = 228, BG_DX = 0.2;
    var GROUND_W = 224, GROUND_H = 129, GROUND_DX = 2.7;
    var BG_COLOR = '#00bbc4';
    var DEG = Math.PI / 180;

    var STATE_READY = 0, STATE_PLAY = 1, STATE_OVER = 2;

    /* ── Assets ──────────────────────────────────────────────────── */
    var assets = {};
    var assetList = [
      ['bird0', './assets/sprites/bird-0.png'],
      ['bird1', './assets/sprites/bird-1.png'],
      ['bird2', './assets/sprites/bird-2.png'],
      ['bg', './assets/sprites/background.png'],
      ['ground', './assets/sprites/ground.png'],
      ['getReady', './assets/sprites/get-ready.png'],
      ['gameOver', './assets/sprites/game-over.png'],
      ['pipeTopBody', './assets/sprites/pipes/pipe-top.png'],
      ['pipeTopMouth', './assets/sprites/pipes/pipe-top-mouth.png'],
      ['pipeBotBody', './assets/sprites/pipes/pipe-bottom.png'],
      ['pipeBotMouth', './assets/sprites/pipes/pipe-bottom-mouth.png'],
      ['medalBronze', './assets/sprites/medals/medal-bronze.png'],
      ['medalSilver', './assets/sprites/medals/medal-silver.png'],
      ['medalGold', './assets/sprites/medals/medal-gold.png'],
      ['medalPlatinum', './assets/sprites/medals/medal-platinum.png'],
    ];
    for (var d = 0; d <= 9; d++) assetList.push(['d'+d, './assets/sprites/digits/digit-'+d+'.png']);

    var sounds = {};
    var soundList = [
      ['flap', './assets/audio/sfx_wing.wav'],
      ['score', './assets/audio/sfx_point.wav'],
      ['hit', './assets/audio/sfx_hit.wav'],
      ['die', './assets/audio/sfx_die.wav'],
      ['swoosh', './assets/audio/sfx_swooshing.wav'],
    ];

    function loadAssets(cb) {
      var total = assetList.length + soundList.length, loaded = 0;
      var called = false;
      function done() {
        loaded++;
        if (!called && loaded >= total) { called = true; cb(); }
      }
      assetList.forEach(function(a) {
        var img = new Image();
        img.onload = done;
        img.onerror = done;
        img.src = a[1];
        assets[a[0]] = img;
      });
      soundList.forEach(function(s) {
        var au = new Audio();
        au.preload = 'auto';
        au.oncanplaythrough = function() { this.oncanplaythrough = null; done(); };
        au.onerror = done;
        au.src = s[1];
        sounds[s[0]] = au;
      });
    }

    function playSound(name) {
      var s = sounds[name];
      if (s) { s.currentTime = 0; s.play().catch(function(){}); }
    }

    /* ── Game State ──────────────────────────────────────────────── */
    var cvs, ctx;
    var state, frame, birdY, vel, birdFr, rot, pipes, nextId;
    var score, best = 0, bgX, groundX, framesSinceLastPipe;
    var loopId = null;
    var groundY, bgY;

    function reset() {
      state = STATE_READY;
      frame = 0;
      birdY = BIRD_Y_START;
      vel = 0;
      birdFr = 0;
      rot = ROT_NEUTRAL;
      pipes = [];
      nextId = 0;
      score = 0;
      framesSinceLastPipe = 0;
      bgX = 0;
      groundX = 0;
      groundY = H - GROUND_H;
      bgY = H - GROUND_H - BG_H;
    }

    /* ── Tile Pipe Drawing ───────────────────────────────────────── */
    var TILE_H = Math.round(25 * (PIPE_W / 26));

    function drawTopPipe(x, y) {
      var mouthY = y + PIPE_H - TILE_H;
      // Body tiles upward from mouth
      for (var i = 0; i < 20; i++) {
        ctx.drawImage(assets.pipeTopBody, x, mouthY - (i+1)*TILE_H, PIPE_W, TILE_H+1);
      }
      // Mouth at bottom
      ctx.drawImage(assets.pipeTopMouth, x, mouthY, PIPE_W, TILE_H);
    }

    function drawBottomPipe(x, y) {
      var topY = y + PIPE_H + PIPE_GAP;
      // Mouth at top
      ctx.drawImage(assets.pipeBotMouth, x, topY, PIPE_W, TILE_H);
      // Body tiles downward
      for (var i = 0; i < 20; i++) {
        ctx.drawImage(assets.pipeBotBody, x, topY + (i+1)*TILE_H, PIPE_W, TILE_H+1);
      }
    }

    /* ── Medal ────────────────────────────────────────────────────── */
    function getMedal() {
      if (score >= 100) return assets.medalPlatinum;
      if (score >= 50) return assets.medalGold;
      if (score >= 25) return assets.medalSilver;
      if (score >= 10) return assets.medalBronze;
      return null;
    }

    /* ── Update ───────────────────────────────────────────────────── */
    function update() {
      if (state === STATE_READY) {
        birdY = BIRD_Y_START; rot = ROT_NEUTRAL; vel = 0;
        if (frame % 20 === 0) birdFr = (birdFr + 1) % 4;
      } else {
        if (frame % 4 === 0) birdFr = (birdFr + 1) % 4;
        vel += GRAVITY;
        birdY += vel;
        if (vel <= FLAP) rot = ROT_UP;
        else if (vel >= FLAP + 2) { rot = ROT_DOWN; birdFr = 1; }
        else rot = ROT_NEUTRAL;

        // Ground
        if (birdY + BIRD_H/2 >= groundY) {
          birdY = groundY - BIRD_H/2;
          birdFr = 2; rot = ROT_DOWN;
          if (state === STATE_PLAY) {
            state = STATE_OVER; playSound('die');
            if (score > best) best = score;
          }
        }
        if (birdY - BIRD_H/2 <= 0) birdY = BIRD_R;
      }

      if (state === STATE_PLAY) {
        // Speed increases 1% per pipe
        var speedMult = 1 + score * 0.01;
        var currentDX = PIPE_DX * speedMult;
        var currentSpawn = Math.max(20, Math.round(PIPE_SPAWN / speedMult));
        // Spawn
        framesSinceLastPipe++;
        if (framesSinceLastPipe >= currentSpawn) {
          framesSinceLastPipe = 0;
          pipes.push({ id: nextId++, x: W, y: Math.floor(Math.random()*(PIPE_MAX_Y-PIPE_MIN_Y+1))+PIPE_MIN_Y });
        }
        // Move & despawn
        for (var i = pipes.length-1; i >= 0; i--) {
          pipes[i].x -= currentDX;
          if (pipes[i].x < -PIPE_W) { pipes.splice(i,1); score++; playSound('score'); }
        }
        // Collision
        var bl = BIRD_X-BIRD_R, br = BIRD_X+BIRD_R, bt = birdY-BIRD_R, bb = birdY+BIRD_R;
        for (var j = 0; j < pipes.length; j++) {
          var p = pipes[j];
          var pl = p.x, pr = p.x+PIPE_W;
          var ttop = p.y, tbot = p.y+PIPE_H;
          var btop2 = p.y+PIPE_H+PIPE_GAP, bbot2 = p.y+2*PIPE_H+PIPE_GAP;
          if (bl < pr && br > pl && bt < tbot && bb > ttop) {
            state = STATE_OVER; playSound('hit'); if (score>best) best=score; break;
          }
          if (bl < pr && br > pl && bt < bbot2 && bb > btop2) {
            state = STATE_OVER; playSound('hit'); if (score>best) best=score; break;
          }
        }
        // Scroll (speed matches pipes)
        bgX = (bgX - BG_DX * speedMult) % BG_W;
        groundX = (groundX - GROUND_DX * speedMult) % (GROUND_W/2);
      }

      frame++;
    }

    /* ── Draw ─────────────────────────────────────────────────────── */
    function draw() {
      ctx.fillStyle = BG_COLOR;
      ctx.fillRect(0, 0, W, H);

      // Background
      for (var bx = bgX; bx < W; bx += BG_W) {
        ctx.drawImage(assets.bg, bx, bgY, BG_W, BG_H);
      }

      // Pipes
      for (var i = 0; i < pipes.length; i++) {
        drawTopPipe(pipes[i].x, pipes[i].y);
        drawBottomPipe(pipes[i].x, pipes[i].y);
      }

      // Ground
      for (var gx = groundX; gx < W + GROUND_W; gx += GROUND_W) {
        ctx.drawImage(assets.ground, gx, groundY, GROUND_W, GROUND_H);
      }

      // Bird
      var birdImgs = [assets.bird0, assets.bird1, assets.bird2, assets.bird1];
      var bImg = birdImgs[birdFr] || assets.bird0;
      ctx.save();
      ctx.translate(BIRD_X, birdY);
      ctx.rotate(rot * DEG);
      ctx.drawImage(bImg, -BIRD_W/2, -BIRD_H/2, BIRD_W, BIRD_H);
      ctx.restore();

      // Score (during play)
      if (state === STATE_PLAY) {
        var ds = score.toString();
        var dw = 18, dh = 27, dgap = 2;
        var tw = ds.length * dw + (ds.length-1)*dgap;
        var sx = (W - tw) / 2;
        for (var di = 0; di < ds.length; di++) {
          ctx.drawImage(assets['d'+ds[di]], sx + di*(dw+dgap), 60, dw, dh);
        }
      }

      // Get Ready
      if (state === STATE_READY) {
        ctx.drawImage(assets.getReady, (W-174)/2, H/2-160, 174, 160);
      }

      // Game Over
      if (state === STATE_OVER) {
        var ow = 226, oh = 158;
        var ox = (W-ow)/2, oy = H/2-oh;
        ctx.drawImage(assets.gameOver, ox, oy, ow, oh);
        // Medal
        var medal = getMedal();
        if (medal) ctx.drawImage(medal, ox+24, oy+88, 44, 44);
        // Score text
        ctx.fillStyle = '#fff';
        ctx.font = 'bold 13px monospace';
        ctx.fillText(score, ox+138, oy+73);
        ctx.fillText(best, ox+138, oy+113);
      }
    }

    /* ── Game Loop (setInterval like Lynx build) ────────────────── */
    function loop() {
      update();
      draw();
    }

    /* ── Input (matches Lynx handleTap exactly) ──────────────────── */
    var inputReady = false;
    var lastInputTime = 0;

    function handleInput(e) {
      if (e) e.preventDefault();
      if (!inputReady) return;

      // Debounce: ignore inputs within 80ms of each other (prevents touch+click double-fire)
      var now = Date.now();
      if (now - lastInputTime < 80) return;
      lastInputTime = now;

      if (state === STATE_READY) {
        state = STATE_PLAY;
        vel = -FLAP;
        playSound('flap');
      } else if (state === STATE_PLAY) {
        vel = -FLAP;
        playSound('flap');
      } else if (state === STATE_OVER) {
        reset();
        playSound('swoosh');
      }
    }

    /* ── Start ────────────────────────────────────────────────────── */
    var gameStarted = false;
    window.startGame = function() {
      if (gameStarted) return;
      gameStarted = true;

      var btn = document.getElementById('play-btn');
      btn.disabled = true;
      btn.textContent = 'Loading...';

      cvs = document.getElementById('canvas');
      ctx = cvs.getContext('2d');

      loadAssets(function() {
        btn.style.display = 'none';
        reset();

        // Bind input
        cvs.addEventListener('click', handleInput);
        cvs.addEventListener('touchstart', handleInput, { passive: false });
        document.addEventListener('keydown', function(e) {
          if (e.code === 'Space' || e.keyCode === 32) handleInput(e);
        });

        // Start game loop (same as Lynx: setInterval 17ms)
        loopId = setInterval(loop, 17);
        draw(); // initial render

        // Enable input after a short delay so Play button click doesn't fire
        setTimeout(function() {
          inputReady = true;
          cvs.focus();
        }, 300);
      });
    };
  })();
  </script>

</body>
</html>
