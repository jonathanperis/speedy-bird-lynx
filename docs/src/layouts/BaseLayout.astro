---
import '../styles/globals.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Speedy Bird | Flappy Bird for Lynx',
  description = 'A pixel art Speedy Bird clone built with the Lynx cross-platform framework. Play in your browser or on mobile iOS and Android.'
} = Astro.props;

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const faviconHref = `${basePath}/favicon.ico`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  'name': 'Speedy Bird',
  'description': description,
  'url': 'https://jonathanperis.github.io/speedy-bird-lynx/',
  'genre': ['Arcade', 'Pixel Art', 'Side-Scroller'],
  'gamePlatform': ['Web Browser', 'iOS', 'Android'],
  'codeRepository': 'https://github.com/jonathanperis/speedy-bird-lynx',
  'isAccessibleForFree': true,
  'author': {
    '@type': 'Person',
    'name': 'Jonathan Peris',
    'url': 'https://jonathanperis.github.io/'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800;900&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Speedy Bird, pixel art, Lynx, ReactLynx, cross-platform, mobile game, side-scroller, open source, flappy bird" />
    <link rel="icon" href={faviconHref} sizes="any" />
    <link rel="canonical" href="https://jonathanperis.github.io/speedy-bird-lynx/" />
    <meta name="theme-color" content="#04111e" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://jonathanperis.github.io/speedy-bird-lynx/" />
    <meta property="og:site_name" content="Speedy Bird" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@jperis_silva" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
    <Analytics />
  </head>
  <body>
    <div class="particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <!-- Pill nav (hidden until hero scrolls off) -->
    <nav id="pill-nav" class="pill-nav">
      <a href="#play">Play</a>
      <a href="#about">About</a>
      <a href="#docs">Docs</a>
      <a href="./docs/">Full Docs</a>
    </nav>

    <slot />

    <script>
      // Pill nav: appear when hero scrolls out of view
      const heroEl = document.getElementById('hero');
      const navEl = document.getElementById('pill-nav');
      if (heroEl && navEl && window.IntersectionObserver) {
        new IntersectionObserver(
          ([e]) => navEl.classList.toggle('visible', !e.isIntersecting)
        ).observe(heroEl);
      }

      // Speed counter loop
      let spd = 1.0;
      const spdEl = document.getElementById('speedNum');
      if (spdEl) {
        setInterval(() => {
          spd += 0.01;
          if (spd > 1.73) spd = 1.0;
          spdEl.textContent = spd.toFixed(2);
        }, 50);
      }

      // Section reveals
      if (window.IntersectionObserver) {
        document.querySelectorAll('.reveal').forEach(el => {
          new IntersectionObserver(
            ([e]) => { if (e.isIntersecting) el.classList.add('visible'); },
            { threshold: 0.1 }
          ).observe(el);
        });

        const meter = document.getElementById('speedMeter');
        if (meter) {
          new IntersectionObserver(
            ([e]) => { if (e.isIntersecting) meter.classList.add('visible'); },
            { threshold: 0.5 }
          ).observe(meter);
        }
      } else {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
      }

      setTimeout(() => {
        document.querySelector('.hero-content')?.classList.add('visible');
      }, 100);
    </script>
  </body>
</html>